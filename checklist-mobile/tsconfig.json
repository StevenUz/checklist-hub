{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@checklisthub/shared": [
        "../checklist-shared/src"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../checklist-shared/src/**/*.ts",
    "nativewind-env.d.ts"
  ]
}