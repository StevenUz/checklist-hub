{
  "expo": {
    "name": "checklist-mobile",
    "slug": "checklist-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "checklistmobile",
    "userInterfaceStyle": "light",
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f8fafc"
        }
      ]
    ],
    "extra": {
      "CHECKLISTHUB_API_URL": "http://localhost:3000"
    },
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": false
    }
  }
}
